# Supabase 연동용. 실제 값은 .env.local에 넣고 커밋하지 않는다.
# 값은 Supabase 대시보드 > Project Settings > API 에서 복사한다.

# mock 유지: 이 줄이 없거나 'supabase'가 아니면 모든 데이터는 mock으로 흐른다.
# 회원 도메인만 실서버로 켜려면 'supabase'로 둔다. (trip/expense 등은 여전히 mock)
NEXT_PUBLIC_DATA_SOURCE=mock

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# publishable 키(sb_publishable_... 또는 레거시 anon JWT). 클라이언트 노출용.
# 시크릿 키(sb_secret_...)는 절대 여기·클라이언트에 넣지 않는다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-KEY
